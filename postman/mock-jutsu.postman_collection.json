{
  "info": {
    "name": "mock-jutsu API",
    "description": "Algorithmic mock data engine — 390+ types, 6 locales.\n\nSet the `baseUrl` environment variable before running.\n- Local dev: `http://localhost:8000`\n- Docker:     `http://localhost:8000`\n\nQuick start:\n1. Import this collection\n2. Import one of the environment files (`local` or `docker`)\n3. Select the environment → Run",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": { "major": 1, "minor": 0, "patch": 0 }
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000", "type": "string" }
  ],
  "item": [

    {
      "name": "🔍 Core",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] },
            "description": "Returns `{\"status\": \"ok\"}` when the API is running."
          }
        },
        {
          "name": "Root — Endpoint List",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/", "host": ["{{baseUrl}}"], "path": [""] },
            "description": "Lists all available endpoints."
          }
        },
        {
          "name": "List All Types",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/list", "host": ["{{baseUrl}}"], "path": ["list"] },
            "description": "Returns all 390+ supported data types with category, locale awareness, and example output."
          }
        },
        {
          "name": "List by Category — financial",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/list?cat=financial",
              "host": ["{{baseUrl}}"],
              "path": ["list"],
              "query": [{ "key": "cat", "value": "financial" }]
            },
            "description": "Filter types by category keyword. Try: financial, identity, banking, health, meta, crypto, telecom, location…"
          }
        },
        {
          "name": "List by Category — identity",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/list?cat=identity",
              "host": ["{{baseUrl}}"],
              "path": ["list"],
              "query": [{ "key": "cat", "value": "identity" }]
            }
          }
        }
      ]
    },

